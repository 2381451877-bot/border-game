            {
                title: "📜 秀才讲大道理", type: "xiucai",
                desc: "一名穷书生非要和你探讨“子曾经曰过”，耽误审查时间。",
                options: [
                    { text: "耐心听讲", score: 2, money: 0, msg: "书生敬佩你，声誉+2。", followupType: "xiucai_listen" },
                    { text: "轰走", score: -1, money: 0, msg: "他到处说你无礼，声誉-1。", followupType: "xiucai_kick" },
                    { text: "收学费", score: 0, money: 20, msg: "你收下20钱教学费。", followupType: "xiucai_money" }
                ]
            },
            {
                title: "🎺 燕小六吹唢呐", type: "xiaoliu",
                desc: "燕小六在关口练习唢呐，吵得旅客纷纷投诉。",
                options: [
                    { text: "一起嗨", score: -1, money: 0, msg: "旅客更生气了，声誉-1。", followupType: "liu_join" },
                    { text: "没收唢呐", score: 1, money: 0, msg: "世界清静了，声誉+1。", followupType: "liu_stop" },
                    { text: "找邢捕头投诉", score: 0, money: 0, msg: "邢捕头罚了小六，事情平息。", followupType: "liu_report" }
                ]
            }
        ];

        // 后续事件
        const FOLLOWUP_EVENTS = {
            tong_kind: [{ title: "💔 湘玉的眼泪", desc: "佟湘玉得知旧相好是骗子，责怪你心太软，声誉-1。", score: -1, money: 0, msg: "声誉-1。" }],
            tong_strict: [{ title: "🏅 廉洁锦旗", desc: "七侠镇商会送来锦旗，声誉+2。", score: 2, money: 0, msg: "声誉+2。" }],
            tong_report: [{ title: "🕵️ 邢捕头嘉奖", desc: "因为你举报有功，声誉+1。", score: 1, money: 0, msg: "声誉+1。" }],
            laobai_help: [{ title: "🤝 老白请客", desc: "白展堂请你喝酒，私房钱+10，声誉+1。", score: 1, money: 10, msg: "声誉+1，钱+10。" }],
            laobai_betray: [{ title: "😠 老白生气", desc: "白展堂跟你冷战，声誉-1。", score: -1, money: 0, msg: "声誉-1。" }],
            laobai_bribe: [{ title: "🕳️ 被人讹诈", desc: "那人继续勒索，你损失20钱。", score: -1, money: -20, msg: "声誉-1，钱-20。" }],
            guo_allow: [{ title: "🥟 郭芙蓉送饺子", desc: "小郭给你带了一笼饺子，私房钱+5。", score: 0, money: 5, msg: "钱+5。" }],
            guo_strict: [{ title: "📖 秀才写诗赞扬", desc: "吕秀才作诗表扬，声誉+1。", score: 1, money: 0, msg: "声誉+1。" }],
            guo_bribe: [{ title: "⚠️ 被巨侠知道", desc: "郭巨侠得知你收钱，声誉-2。", score: -2, money: 0, msg: "声誉-2。" }],
            xiucai_listen: [{ title: "📚 书生成名", desc: "书生中了举人回来感谢，声誉+2。", score: 2, money: 0, msg: "声誉+2。" }],
            xiucai_kick: [{ title: "😤 坏名声", desc: "七侠镇文人圈抵制你，声誉-1。", score: -1, money: 0, msg: "声誉-1。" }],
            xiucai_money: [{ title: "📖 抄袭丑闻", desc: "书生举报你剽窃文章，声誉-2，钱-10。", score: -2, money: -10, msg: "声誉-2，钱-10。" }],
            liu_join: [{ title: "🎶 集体投诉", desc: "更多旅客投诉，声誉-2。", score: -2, money: 0, msg: "声誉-2。" }],
            liu_stop: [{ title: "📯 小六怀恨", desc: "燕小六偷偷搞破坏，声誉-1。", score: -1, money: 0, msg: "声誉-1。" }],
            liu_report: [{ title: "👮 邢捕头请客", desc: "邢捕头请你喝酒，钱+5。", score: 0, money: 5, msg: "钱+5。" }]
        };

        // DOM 元素
        const officerNameSpan = document.getElementById("officerName");
        const scoreSpan = document.getElementById("scoreValue");
        const moneySpan = document.getElementById("moneyValue");
        const caseCounterSpan = document.getElementById("caseCounter");
        const totalCasesSpan = document.getElementById("totalCasesSpan");
        const dayInfoSpan = document.getElementById("dayInfo");
        const approveBtn = document.getElementById("approveBtn");
        const rejectBtn = document.getElementById("rejectBtn");
        const resetBtn = document.getElementById("resetBtn");
        const feedbackDiv = document.getElementById("feedbackMsg");
        const eventArea = document.getElementById("dynamicEventArea");
        const dailyEffectArea = document.getElementById("dailyEffectArea");
        const decreeWarning = document.getElementById("decreeWarning");
        const amuletCountSpan = document.getElementById("amuletCount");
        const lensCountSpan = document.getElementById("lensCount");
        const bribeExemptSpan = document.getElementById("bribeExemptCount");
        const declNameSpan = document.getElementById("declName");
        const declIDSpan = document.getElementById("declID");
        const declPhotoSpan = document.getElementById("declPhoto");
        const declFingerSpan = document.getElementById("declFinger");
        const docNameSpan = document.getElementById("docName");
        const docIDSpan = document.getElementById("docID");
        const docPhotoSpan = document.getElementById("docPhoto");
        const docFingerSpan = document.getElementById("docFinger");
        const docExpirySpan = document.getElementById("docExpiry");
        const docIssueSpan = document.getElementById("docIssue");

        // 辅助函数
        function randomElem(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
        function randomInt(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }
        function generateName() { return `${randomElem(FIRST_NAMES)}·${randomElem(LAST_NAMES)}`; }
        function generateID() { return `TJ-${randomInt(1000, 9999)}`; }
        function generateAppearance() { return randomElem(APPEARANCES); }
        function generateCode() { return randomElem(CODES); }
        function generateValidExpiry() { return `2025-${String(randomInt(1,12)).padStart(2,'0')}-${String(randomInt(1,28)).padStart(2,'0')}`; }
        function generateExpiredExpiry() { return `2024-${String(randomInt(1,12)).padStart(2,'0')}-${String(randomInt(1,28)).padStart(2,'0')}`; }
        function isExpiryValid(expiry) { return expiry >= "2025-01-01"; }

        let score = 0, money = 0, processedCount = 0, gameActive = true, currentDay = 1;
        let extraCheckFlag = false, bribeBoostFlag = false;
        let dailyEffect = null, activeEvent = null;
        let amulets = 0, lenses = 0, bribeExempt = 0;
        let playerChoices = {}, followupTriggered = new Set(), motherForced = false;
        let stats = {
            totalDecisions:0, correctDecisions:0, totalBribesTaken:0, totalBribesRefused:0,
            amuletUsed:0, lensUsed:0, itemsBought:{ amulet:0, lens:0, exempt:0 },
            eventsTriggered:new Set(), consecutiveCorrectMax:0, consecutiveWrongMax:0, kindnessChoices:0
        };
        let consecutiveCorrect = 0, consecutiveWrong = 0;
        let currentApplicant = null;

        function generateValidApplicant() {
            let name = generateName(), id = generateID(), photo = generateAppearance(), finger = generateCode();
            return {
                declaration: { name, id, photo, finger },
                document: { name, id, photo, finger, expiry: generateValidExpiry(), issueCity: LEGAL_CITY }
            };
        }

        function generateErroneousApplicant(validBase) {
            let faultyDecl = { ...validBase.declaration };
            let faultyDoc = { ...validBase.document };
            let errorCount = randomInt(1, MAX_ERRORS);
            if (extraCheckFlag) errorCount = Math.min(MAX_ERRORS, errorCount + 1);
            let errTypes = [];
            while (errTypes.length < errorCount) {
                let e = randomInt(0, 5);
                if (!errTypes.includes(e)) errTypes.push(e);
            }
            for (let e of errTypes) {
                if (e === 0) { let nn = generateName(); while (nn === faultyDecl.name) nn = generateName(); faultyDoc.name = nn; }
                else if (e === 1) { let nid = generateID(); while (nid === faultyDecl.id) nid = generateID(); faultyDoc.id = nid; }
                else if (e === 2) { let np = generateAppearance(); while (np === faultyDecl.photo) np = generateAppearance(); faultyDoc.photo = np; }
                else if (e === 3) { let nf = generateCode(); while (nf === faultyDecl.finger) nf = generateCode(); faultyDoc.finger = nf; }
                else if (e === 4) faultyDoc.expiry = generateExpiredExpiry();
                else if (e === 5) faultyDoc.issueCity = randomElem(ILLEGAL_CITIES);
            }
            return { declaration: faultyDecl, document: faultyDoc };
        }

        function generateApplicant() {
            let isLegal = Math.random() < LEGAL_PROBABILITY;
            let valid = generateValidApplicant();
            let data = isLegal ? valid : generateErroneousApplicant(valid);
            let shouldApprove = (
                data.declaration.name === data.document.name &&
                data.declaration.id === data.document.id &&
                data.declaration.photo === data.document.photo &&
                data.declaration.finger === data.document.finger &&
                isExpiryValid(data.document.expiry) &&
                data.document.issueCity === LEGAL_CITY
            );
            if (lenses > 0 && !shouldApprove) {
                let hint = "";
                if (data.declaration.name !== data.document.name) hint = "🔍 盗圣提示：姓名对不上！";
                else if (data.declaration.id !== data.document.id) hint = "🔍 盗圣提示：江湖ID不符！";
                else if (data.declaration.photo !== data.document.photo) hint = "🔍 盗圣提示：相貌描述有问题！";
                else if (data.declaration.finger !== data.document.finger) hint = "🔍 盗圣提示：暗号指纹错误！";
                else if (!isExpiryValid(data.document.expiry)) hint = "🔍 盗圣提示：文牒已过期！";
                else if (data.document.issueCity !== LEGAL_CITY) hint = "🔍 盗圣提示：签发地不是七侠镇！";
                else hint = "🔍 盗圣挠头：都一致，但直觉不对……";
                lenses--;
                stats.lensUsed++;
                updateItemUI();
                feedbackDiv.innerHTML = `${hint}<br>${feedbackDiv.innerHTML}`;
            }
            return { ...data, shouldApprove };
        }

        function renderApplicant(a) {
            declNameSpan.innerText = a.declaration.name;
            declIDSpan.innerText = a.declaration.id;
            declPhotoSpan.innerText = a.declaration.photo;
            declFingerSpan.innerText = a.declaration.finger;
            docNameSpan.innerText = a.document.name;
            docIDSpan.innerText = a.document.id;
            docPhotoSpan.innerText = a.document.photo;
            docFingerSpan.innerText = a.document.finger;
            docExpirySpan.innerText = a.document.expiry;
            docIssueSpan.innerText = a.document.issueCity;
        }

        function updateStatsUI() {
            scoreSpan.innerText = score;
            moneySpan.innerText = money;
            caseCounterSpan.innerText = processedCount;
            totalCasesSpan.innerText = TOTAL_CASES;
            dayInfoSpan.innerText = `第 ${currentDay} / ${TOTAL_DAYS} 日`;
            updateItemUI();
        }

        function updateItemUI() {
            amuletCountSpan.innerText = amulets;
            lensCountSpan.innerText = lenses;
            bribeExemptSpan.innerText = bribeExempt;
        }

        function applyScoreModifier(delta, isCorrect) {
            if (dailyEffect && dailyEffect.effect) return dailyEffect.effect(delta, isCorrect);
            return delta;
        }

        function tryTriggerFollowup() {
            if (processedCount < 8) return;
            let possible = Object.keys(playerChoices).filter(k => playerChoices[k] && !followupTriggered.has(k) && FOLLOWUP_EVENTS[k]);
            if (possible.length === 0) return;
            if (Math.random() > 0.4) return;
            let type = randomElem(possible);
            let evList = FOLLOWUP_EVENTS[type];
            if (evList && evList.length) {
                let ev = randomElem(evList);
                followupTriggered.add(type);
                activeEvent = { resolved: false };
                eventArea.style.display = "block";
                let html = `<strong>⚡ ${ev.title}</strong><br>${ev.desc}<div class="event-buttons"><button class="event-btn" data-score="${ev.score}" data-money="${ev.money}" data-msg="${ev.msg}">知晓</button></div>`;
                eventArea.innerHTML = html;
                document.querySelectorAll('.event-btn').forEach(btn => {
                    btn.onclick = () => {
                        score += parseInt(btn.dataset.score) || 0;
                        money += parseInt(btn.dataset.money) || 0;
                        if (score < 0) score = 0;
                        if (money < 0) money = 0;
                        updateStatsUI();
                        feedbackDiv.innerHTML = `✨ ${btn.dataset.msg}`;
                        activeEvent.resolved = true;
                        eventArea.style.display = "none";
                        activeEvent = null;
                    };
                });
            }
        }

        function showEvent(eventData) {
            activeEvent = { ...eventData, resolved: false };
            stats.eventsTriggered.add(eventData.type);
            eventArea.style.display = "block";
            let html = `<strong>⚡ ${eventData.title}</strong><br>${eventData.desc}<div class="event-buttons">`;
            eventData.options.forEach((opt, idx) => {
                html += `<button class="event-btn" data-opt="${idx}">${opt.text}</button>`;
            });
            html += `</div>`;
            eventArea.innerHTML = html;
            document.querySelectorAll('.event-btn').forEach(btn => {
                btn.onclick = () => {
                    let idx = parseInt(btn.dataset.opt);
                    let chosen = eventData.options[idx];
                    score += chosen.score;
                    money += chosen.money;
                    if (score < 0) score = 0;
                    if (money < 0) money = 0;
                    updateStatsUI();
                    feedbackDiv.innerHTML = `✨ ${chosen.msg}`;
                    if (chosen.kindness) stats.kindnessChoices++;
                    if (chosen.followupType) playerChoices[chosen.followupType] = true;
                    activeEvent.resolved = true;
                    eventArea.style.display = "none";
                    activeEvent = null;
                    tryTriggerFollowup();
                };
            });
        }

        function triggerAdvancedEvent() {
            if (processedCount >= TOTAL_CASES) return;
            if (activeEvent) return;
            if (!motherForced && processedCount >= 12) {
                motherForced = true;
                let ev = ADVANCED_EVENTS.find(e => e.type === "tong");
                if (ev) { showEvent(ev); return; }
            }
            let rate = EVENT_TRIGGER_RATE;
            if (bribeBoostFlag) rate = Math.min(0.9, rate + 0.2);
            if (Math.random() > rate) return;
            showEvent(randomElem(ADVANCED_EVENTS));
        }

        function handleDecision(action) {
            if (!gameActive || processedCount >= TOTAL_CASES) return;
            if (activeEvent && !activeEvent.resolved) {
                feedbackDiv.innerHTML = "⚠️ 先处理眼前江湖事！";
                return;
            }
            let should = currentApplicant.shouldApprove;
            let isCorrect = (action === 'approve' && should) || (action === 'reject' && !should);
            let delta = isCorrect ? 1 : -1;
            stats.totalDecisions++;
            if (isCorrect) stats.correctDecisions++;
            let finalDelta = delta;
            if (!isCorrect && amulets > 0) {
                finalDelta = 0;
                amulets--;
                stats.amuletUsed++;
                updateItemUI();
                feedbackDiv.innerHTML = "🛡️ 免罪护符生效，保住声誉！";
            }
            finalDelta = applyScoreModifier(finalDelta, isCorrect);
            let bonus = 0;
            if (isCorrect) {
                consecutiveCorrect++;
                consecutiveWrong = 0;
                if (consecutiveCorrect >= 2) { bonus = 1; consecutiveCorrect = 0; }
            } else {
                consecutiveWrong++;
                consecutiveCorrect = 0;
                if (consecutiveWrong >= 2) { bonus = -1; consecutiveWrong = 0; }
            }
            finalDelta += bonus;
            score += finalDelta;
            if (score < 0) score = 0;
            processedCount++;
            updateStatsUI();
            feedbackDiv.innerHTML = `${isCorrect ? "✅ 秉公处理" : "❌ 判断有误"} (${delta > 0 ? `+${delta}` : delta}分${bonus !== 0 ? ` ${bonus > 0 ? '+' + bonus : bonus}` : ''}) 当前声誉:${score}`;
            if (processedCount % DAY_CASES === 0 && processedCount !== 0 && processedCount < TOTAL_CASES) endOfDay();
            else if (processedCount >= TOTAL_CASES) endGame();
            else { triggerAdvancedEvent(); nextApplicant(); }
        }

        function nextApplicant() {
            currentApplicant = generateApplicant();
            renderApplicant(currentApplicant);
        }

        function endOfDay() {
            if (currentDay >= TOTAL_DAYS) return;
            feedbackDiv.innerHTML = `📆 第${currentDay}日毕，明日继续营业。声誉:${score} 私房钱:${money}`;
            consecutiveCorrect = 0;
            consecutiveWrong = 0;
            currentDay++;
            extraCheckFlag = false;
            bribeBoostFlag = false;
            applyDailyEffect();
            updateStatsUI();
            currentApplicant = generateApplicant();
            renderApplicant(currentApplicant);
        }

        function applyDailyEffect() {
            dailyEffect = randomElem(DAILY_EFFECTS);
            extraCheckFlag = dailyEffect.extraCheck || false;
            bribeBoostFlag = dailyEffect.bribeBoost || false;
            if (dailyEffect.startMoney) {
                money += dailyEffect.startMoney;
                updateStatsUI();
                feedbackDiv.innerHTML = `🎁 ${dailyEffect.name}：意外之财+${dailyEffect.startMoney}钱。`;
            }
            dailyEffectArea.style.display = "block";
            dailyEffectArea.innerHTML = `📌 今日效果 · ${dailyEffect.name}：${dailyEffect.desc}`;
            decreeWarning.style.display = "none";
        }

        function endGame() {
            gameActive = false;
            approveBtn.disabled = true;
            rejectBtn.disabled = true;
            let correctRate = stats.totalDecisions === 0 ? 0 : Math.round((stats.correctDecisions / stats.totalDecisions) * 100);
            let title = "", desc = "";
            if (money >= 200 && score <= 8) { title = "🚨 被逐出同福"; desc = "你贪赃枉法，佟掌柜一气之下将你赶出客栈，江湖再无容身之处。"; }
            else if (score >= 22 && money <= 30) { title = "🏆 新晋掌柜"; desc = "佟湘玉提拔你当二掌柜，同福客栈名声大噪，你成了七侠镇传奇。"; }
            else if (score >= 18) { title = "⭐ 关中侠客"; desc = "你公正严明，获赠‘关中大侠’牌匾，受百姓敬仰。"; }
            else if (money >= 150) { title = "💰 富甲一方"; desc = "你积累大量私房钱，却丢了名声，被人指指点点。"; }
            else if (score <= 5) { title = "😵 背锅跑堂"; desc = "屡屡犯错，被发配去后厨洗碗，永无出头之日。"; }
            else { title = "📋 普通伙计"; desc = "无功无过，继续在同福客栈端盘子。"; }
            let achievements = [];
            if (stats.correctDecisions >= 25) achievements.push("⚖️ 铁面判官");
            if (money >= 180) achievements.push("💰 商业鬼才");
            if (stats.lensUsed >= 8) achievements.push("🔍 盗圣传人");
            if (stats.kindnessChoices >= 3) achievements.push("🕊️ 心太软");
            let achStr = achievements.length ? `🏅 成就：${achievements.slice(0, 3).join(" · ")}` : "";
            feedbackDiv.innerHTML = `<div class="end-report"><h3>📜 江湖总结 · ${title}</h3><p>声誉值: ${score} | 私房钱: ${money}<br>正确率: ${stats.correctDecisions}/${stats.totalDecisions} (${correctRate}%)<br>${desc}<br>${achStr}</p><p style="margin-top:10px;">🎭 点击「重开江湖」再续前缘</p></div>`;
        }

        function resetGame() {
            let rname = randomElem(OFFICER_NAMES);
            officerNameSpan.innerText = rname;
            score = 0; money = 0; processedCount = 0; gameActive = true; currentDay = 1;
            extraCheckFlag = false; bribeBoostFlag = false;
            amulets = 0; lenses = 0; bribeExempt = 0;
            activeEvent = null; eventArea.style.display = "none";
            approveBtn.disabled = false; rejectBtn.disabled = false;
            playerChoices = {}; followupTriggered.clear(); motherForced = false;
            stats = {
                totalDecisions:0, correctDecisions:0, totalBribesTaken:0, totalBribesRefused:0,
                amuletUsed:0, lensUsed:0, itemsBought:{ amulet:0, lens:0, exempt:0 },
                eventsTriggered:new Set(), consecutiveCorrectMax:0, consecutiveWrongMax:0, kindnessChoices:0
            };
            consecutiveCorrect = 0; consecutiveWrong = 0;
            applyDailyEffect();
            currentApplicant = generateApplicant();
            renderApplicant(currentApplicant);
            updateStatsUI();
            feedbackDiv.innerHTML = "🏮 新的一轮，六项法则刻心间！";
        }

        // 商店
        const modal = document.getElementById("shopModal");
        const shopBtn = document.getElementById("shopBtn");
        const closeModal = document.getElementById("closeModal");
        const buyAmulet = document.getElementById("buyAmulet");
        const buyLens = document.getElementById("buyLens");
        const buyExempt = document.getElementById("buyExempt");
        shopBtn.onclick = () => modal.style.display = "flex";
        closeModal.onclick = () => modal.style.display = "none";
        window.onclick = (e) => { if (e.target === modal) modal.style.display = "none"; };
        buyAmulet.onclick = () => { if (money >= 30) { money -= 30; amulets++; stats.itemsBought.amulet++; updateStatsUI(); feedbackDiv.innerHTML = "🛡️ 购得免罪护符一枚！"; modal.style.display = "none"; } else alert("私房钱不够！"); };
        buyLens.onclick = () => { if (money >= 20) { money -= 20; lenses += 3; stats.itemsBought.lens++; updateStatsUI(); feedbackDiv.innerHTML = "🔍 盗圣放大镜到手！"; modal.style.display = "none"; } else alert("钱两不足！"); };
        buyExempt.onclick = () => { if (money >= 40) { money -= 40; bribeExempt++; stats.itemsBought.exempt++; updateStatsUI(); feedbackDiv.innerHTML = "💰 贿赂豁免券，防身用！"; modal.style.display = "none"; } else alert("囊中羞涩！"); };

        approveBtn.onclick = () => { if (gameActive) handleDecision('approve'); };
        rejectBtn.onclick = () => { if (gameActive) handleDecision('reject'); };
        resetBtn.onclick = resetGame;

        const startBtn = document.getElementById("startGameBtn");
        const intro = document.getElementById("introOverlay");
        const container = document.getElementById("gameContainer");
        startBtn.onclick = () => {
            intro.style.display = "none";
            container.style.display = "block";
            resetGame();
        };
    })();
</script>
</body>
</html>
